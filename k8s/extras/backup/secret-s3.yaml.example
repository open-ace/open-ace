# Open ACE - AWS S3 Backup Credentials
# Copy this file to secret-s3.yaml and fill in your credentials
# Issue #1853
#
# Usage:
#   cp secret-s3.yaml.example secret-s3.yaml
#   # Edit secret-s3.yaml with your credentials
#   kubectl apply -f secret-s3.yaml

apiVersion: v1
kind: Secret
metadata:
  name: backup-storage-credentials
  namespace: open-ace
  labels:
    app.kubernetes.io/name: open-ace
    app.kubernetes.io/component: backup
type: Opaque
stringData:
  # AWS S3 credentials
  AWS_ACCESS_KEY_ID: "YOUR_AWS_ACCESS_KEY_ID"
  AWS_SECRET_ACCESS_KEY: "YOUR_AWS_SECRET_ACCESS_KEY"
  AWS_REGION: "us-east-1"

  # S3 bucket name
  S3_BUCKET: "your-backup-bucket-name"

  # Leave empty for AWS S3 standard endpoint
  # For S3-compatible storage (MinIO, Ceph, etc.), set the endpoint URL
  S3_ENDPOINT: ""

  # Example for MinIO:
  # S3_ENDPOINT: "http://minio.example.com:9000"
