# Open ACE - MinIO Backup Credentials
# Copy this file to secret-minio.yaml and fill in your credentials
# Issue #1853
#
# Usage:
#   cp secret-minio.yaml.example secret-minio.yaml
#   # Edit secret-minio.yaml with your credentials
#   kubectl apply -f secret-minio.yaml

apiVersion: v1
kind: Secret
metadata:
  name: backup-storage-credentials
  namespace: open-ace
  labels:
    app.kubernetes.io/name: open-ace
    app.kubernetes.io/component: backup
type: Opaque
stringData:
  # MinIO credentials
  AWS_ACCESS_KEY_ID: "minio-access-key"
  AWS_SECRET_ACCESS_KEY: "minio-secret-key"

  # Region (required by AWS CLI, can be any value for MinIO)
  AWS_REGION: "us-east-1"

  # MinIO bucket name
  S3_BUCKET: "open-ace-backups"

  # MinIO endpoint URL
  S3_ENDPOINT: "http://minio.example.com:9000"

  # For MinIO deployed in Kubernetes:
  # S3_ENDPOINT: "http://minio.minio-namespace.svc.cluster.local:9000"