{
  "host_name": "ai-lab",
  "server": {
    "upload_auth_key": "<UPLOAD_AUTH_KEY>",
    "server_url": "http://<SERVER_IP>:5001"
  },
  "tools": {
    "openclaw": {
      "enabled": true,
      "token_env": "OPENCLAW_TOKEN",
      "gateway_url": "http://localhost:18789"
    },
    "claude": {
      "enabled": true
    },
    "qwen": {
      "enabled": true
    }
  },
  "cron": {
    "enabled": true,
    "run_time": "00:30"
  }
}
