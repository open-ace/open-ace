{
  "host_name": "<HOST_NAME>",
  "database": {
    "type": "sqlite",
    "path": "~/.open-ace/ace.db",
    "url": null
  },
  "server": {
    "upload_auth_key": "<UPLOAD_AUTH_KEY>",
    "server_url": "http://localhost:5001",
    "web_port": 5001,
    "web_host": "0.0.0.0"
  },
  "workspace": {
    "enabled": false,
    "url": "http://localhost:8080"
  },
  "tools": {
    "openclaw": {
      "enabled": true,
      "token_env": "OPENCLAW_TOKEN",
      "gateway_url": "http://localhost:18789",
      "hostname": "<HOST_NAME>"
    },
    "claude": {
      "enabled": true,
      "hostname": "<HOST_NAME>"
    },
    "qwen": {
      "enabled": true,
      "hostname": "<HOST_NAME>"
    }
  },
  "cron": {
    "enabled": true,
    "run_time": "00:30"
  },
  "feishu": {
    "app_id": "<FEISHU_APP_ID>",
    "app_secret": "<FEISHU_APP_SECRET>"
  }
}
