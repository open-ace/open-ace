{
  "host_name": "<HOST_NAME>",
  "database": {
    "type": "postgresql",
    "url": "postgresql://user:password@localhost:5432/openace"
  },
  "server": {
    "upload_auth_key": "<UPLOAD_AUTH_KEY>",
    "server_url": "http://localhost:5000",
    "web_port": 5000,
    "web_host": "0.0.0.0"
  },
  "workspace": {
    "enabled": false,
    "url": "http://localhost",
    "multi_user_mode": false,
    "port_range_start": 9000,
    "port_range_end": 9999,
    "max_instances": 30,
    "idle_timeout_minutes": 30,
    "cleanup_interval_minutes": 5,
    "token_secret": "",
    "webui_path": ""
  },
  "tools": {
    "openclaw": {
      "enabled": true,
      "token_env": "OPENCLAW_TOKEN",
      "gateway_url": "http://localhost:18789",
      "hostname": "<HOST_NAME>"
    },
    "claude": {
      "enabled": true,
      "hostname": "<HOST_NAME>"
    },
    "qwen": {
      "enabled": true,
      "hostname": "<HOST_NAME>"
    }
  },
  "cron": {
    "enabled": true,
    "run_time": "00:30"
  },
  "feishu": {
    "app_id": "<FEISHU_APP_ID>",
    "app_secret": "<FEISHU_APP_SECRET>"
  },
  "auth": {
    "auth_type": "openai",
    "env": {
      "OPENAI_API_KEY": "<YOUR_API_KEY>",
      "OPENAI_BASE_URL": "https://api.openai.com/v1"
    }
  }
}
