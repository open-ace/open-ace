# Open ACE - Installation Configuration
# Copy this file to install.conf and modify as needed
#
# Usage: ./scripts/install.sh --config install.conf

# ============================================================================
# Deployment Settings
# ============================================================================

# Deployment user (the user to run the service as)
DEPLOY_USER=${USER}

# Installation path
DEPLOY_PATH=$HOME/open-ace

# ============================================================================
# Remote Deployment (optional)
# ============================================================================
# To deploy to a remote machine via SSH, uncomment and set DEPLOY_HOST.
# If DEPLOY_HOST is empty or not set, installation will be local.

# DEPLOY_HOST=192.168.1.100

# ============================================================================
# Systemd Service Configuration (optional)
# ============================================================================
# If INSTALL_SERVICE=yes, the installer will create a systemd service
# for easy management with systemctl commands.
# Note: Root/sudo privileges are required to install systemd service.

# INSTALL_SERVICE=yes
# SERVICE_PORT=5001
# SERVICE_HOST=0.0.0.0

# ============================================================================
# Examples
# ============================================================================

# Example 1: Local installation (single machine deployment)
# DEPLOY_USER=${USER}
# DEPLOY_PATH=$HOME/open-ace

# Example 2: Deploy to 192.168.64.2 via SSH
# DEPLOY_HOST=192.168.64.2
# DEPLOY_USER=root
# DEPLOY_PATH=/home/rhuang/open-ace

# Example 3: Local installation with systemd service
# DEPLOY_USER=${USER}
# DEPLOY_PATH=$HOME/open-ace
# INSTALL_SERVICE=yes
# SERVICE_PORT=5001
# SERVICE_HOST=0.0.0.0