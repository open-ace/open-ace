# AI Token Analyzer - Installation Configuration
# Copy this file to install.conf and modify as needed
#
# Usage: ./scripts/install.sh --config install.conf

# ============================================================================
# Deployment Settings
# ============================================================================

# Deployment user (the user to run the service as)
DEPLOY_USER=${USER}

# Installation path
DEPLOY_PATH=$HOME/ai-token-analyzer

# ============================================================================
# Remote Deployment (optional)
# ============================================================================
# To deploy to a remote machine via SSH, uncomment and set DEPLOY_HOST.
# If DEPLOY_HOST is empty or not set, installation will be local.

# DEPLOY_HOST=192.168.1.100

# ============================================================================
# Examples
# ============================================================================

# Example 1: Local installation (single machine deployment)
# DEPLOY_USER=${USER}
# DEPLOY_PATH=$HOME/ai-token-analyzer

# Example 2: Deploy to 192.168.64.2 via SSH
# DEPLOY_HOST=192.168.64.2
# DEPLOY_USER=root
# DEPLOY_PATH=/home/rhuang/ai-token-analyzer